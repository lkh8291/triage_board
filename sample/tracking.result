    ...
    if (i10 == 300) {
        if (intent.hasExtra(BUNDLE_KEY_LOCATION_RESULT) && (bundleExtra2 = intent.getBundleExtra(BUNDLE_KEY_LOCATION_RESULT)) != null) {
            intent.putExtra("pending_location", new Intent().putExtras(bundleExtra2).toUri(1));
            ...
        }
    } else if (i10 == 100) {
        if (intent.hasExtra("selectedItems")) {
            int intExtra = intent.getIntExtra("selectedCount", 0);
            ArrayList parcelableArrayListExtra = intent.getParcelableArrayListExtra("selectedItems");
            ...
            intent.putExtra("pending_img_uris...", ((Uri) obj).toString());
        } else if (intent.getData() != null) {
            intent.putExtra("pending_img_uri", intent.getData().toString());
        } else if (intent.getClipData() != null) {
            // ClipData URIs read and re-stamped into extras
        }
    } else if (i10 == 500 && ...extra_skip_alert_state...) {
        ...new Gson().toJson(c3697w);  // Gson serialize attacker-provided Parcelable
    }
    this.f29992d.putExtra("pending_data", intent.toUri(1));
    ...
    c4000w0.k1().t(i10, i11, intent);                 // âš  fragment onActivityResult â€” consumes attacker intent
    return true;
